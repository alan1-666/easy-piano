# Copy to .env (gitignored) and customize per environment.
#
# The URL the app hits for API calls. EXPO_PUBLIC_ prefix is required
# so Expo inlines the value at build time and exposes it via process.env.
#
# Local dev via SSH tunnel (default when unset):
#   EXPO_PUBLIC_API_BASE_URL=http://localhost:18080/v1
# Direct staging (once cloud security group allows 80/443):
#   EXPO_PUBLIC_API_BASE_URL=https://117-72-160-220.nip.io/v1
# Production:
#   EXPO_PUBLIC_API_BASE_URL=https://api.easypiano.app/v1
EXPO_PUBLIC_API_BASE_URL=http://localhost:18080/v1
